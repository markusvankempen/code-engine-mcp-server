node_modules/
.DS_Store

# Source code lives in the private dev repo only
src/
__tests__/
build/
scripts/

# VS Code extension — README and UI assets are public; source/build stay in dev repo
vscode-extension/*
!vscode-extension/README.md
!vscode-extension/icon.png
!vscode-extension/images/

# Examples — container demos + supergateway are public
# deploy-mcp-server-to-code-engine: only README is public, source stays in dev repo
examples/deploy-mcp-server-to-code-engine/*
!examples/deploy-mcp-server-to-code-engine/README.md

# provenance-addon — public (docs + tooling)
# (no exclusion needed — whole folder is public)
provenance-addon/.keys/

# TypeScript / build config
tsconfig.json
tsconfig.test.json
jest.config.ts
package.json
package-lock.json
mise.toml
run-client.sh
test-tools.sh

# Local editor and MCP runtime config
.vscode/mcp.json

# Local secrets
.env
.env.*
!.env.example

# Internal release notes / publishing scripts (local only)
internal/

# OpenAPI spec — dev repo only
api/

# Local MCP publisher tokens
.mcpregistry_github_token
.mcpregistry_registry_token

# VS Code extension VSIX
*.vsix

# Dev-only files at root (bridge, Docker, scratch)
/Dockerfile
/.dockerignore
bridge.mjs
dot.env.example
scratch/

# GitHub skills are public (Cursor deploy skill)
